# Telegram Bot Token (получите у @BotFather)
BOT_TOKEN=your_bot_token_here

# ID администратора для получения заказов
ADMIN_ID=your_admin_id_here

# ID канала для обязательной подписки
CHANNEL_ID=@your_channel

# Публичная ссылка на канал
CHANNEL_URL=https://t.me/your_channel

# Опционально: прокси для сервера
# PROXY_URL=http://user:pass@host:port

# Опционально: приватный канал Merix Academy
PRIVATE_CHANNEL_ID=-1000000000000

# Реквизиты ручной оплаты
PAYMENT_CARD_ALIF=+992000000000
PAYMENT_CARD_MASTERCARD=0000000000000000

# YooMoney (обязательно только если используете автоплатежи)
YOOMONEY_TOKEN=your_yoomoney_token_here
YOOMONEY_WALLET=your_yoomoney_wallet_here
